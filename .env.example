HOST=0.0.0.0
PORT=5050
DEBUG=0
DATASET_PATH=data/processed/heritage_items.json

# Optional OpenAI-compatible chat completion API.
# DeepSeek Flash example:
# AI_BASE_URL=https://api.deepseek.com
# AI_MODEL=deepseek-v4-flash
# AI_TIMEOUT=60
# AI_API_KEY=

# Optional OpenAI-compatible embedding API.
# Build index with: python .\scripts\maintenance\rebuild_embedding_index.py --no-resume
EMBEDDING_BASE_URL=https://api.vectorengine.ai/v1
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_TIMEOUT=60
EMBEDDING_BATCH_SIZE=64
EMBEDDING_WORKERS=6
EMBEDDING_REQUEST_TIMEOUT=5
EMBEDDING_MAX_RETRIES=4
EMBEDDING_RETRY_BACKOFF=3
EMBEDDING_REQUEST_DELAY=0
EMBEDDING_INDEX_PATH=data/embeddings/heritage_embeddings.json
EMBEDDING_TEXT_MAX_CHARS=1400
EMBEDDING_MIN_SCORE=0.15
SEARCH_USE_EMBEDDING=0
EMBEDDING_API_KEY=

# Optional server-side Volcengine TTS.
# Get AppID, Access Token, and Cluster from the Volcengine Speech console.
# To use the AI API for TTS instead, set OPENAI_TTS_ENABLED=1.
# Requires your AI_BASE_URL to support /v1/audio/speech (e.g. OpenAI, not DeepSeek).
OPENAI_TTS_ENABLED=0
VOLC_TTS_ENABLED=1
VOLC_TTS_API_VERSION=auto
VOLC_TTS_API_KEY=
VOLC_TTS_APP_ID=
VOLC_TTS_ACCESS_TOKEN=
VOLC_TTS_CLUSTER=volcano_tts
VOLC_TTS_RESOURCE_ID=volc.service_type.10029
VOLC_TTS_VOICE_TYPE=zh_female_gaolengyujie_emo_v2_mars_bigtts
VOLC_TTS_EMOTION=coldness
VOLC_TTS_EMOTION_SCALE=4
VOLC_TTS_ENCODING=mp3
VOLC_TTS_RATE=24000
VOLC_TTS_SPEED_RATIO=1.0
VOLC_TTS_VOLUME_RATIO=1.0
VOLC_TTS_PITCH_RATIO=1.0
VOLC_TTS_TIMEOUT=20
TTS_CACHE_DIR=tmp/tts
