HOST=0.0.0.0
PORT=5050
DEBUG=0
DATASET_PATH=data/processed/heritage_items.json

# Optional OpenAI-compatible chat completion API.
# Zhipu example:
# AI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# AI_MODEL=glm-4-flash
# AI_TIMEOUT=60
# AI_API_KEY=

# Optional OpenAI-compatible embedding API.
# Build index with: python .\scripts\build_embeddings.py
EMBEDDING_BASE_URL=https://api.vectorengine.ai/v1
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_TIMEOUT=60
EMBEDDING_BATCH_SIZE=64
EMBEDDING_WORKERS=6
EMBEDDING_REQUEST_TIMEOUT=5
EMBEDDING_MAX_RETRIES=4
EMBEDDING_RETRY_BACKOFF=3
EMBEDDING_REQUEST_DELAY=0
EMBEDDING_INDEX_PATH=data/embeddings/heritage_embeddings.json
EMBEDDING_TEXT_MAX_CHARS=1400
EMBEDDING_MIN_SCORE=0.15
SEARCH_USE_EMBEDDING=0
EMBEDDING_API_KEY=
